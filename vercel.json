{
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "nodeVersion": "24.x",
  "root": ".",
  "env": {
    "NEXTAUTH_SECRET": {
      "required": true
    },
    "NEXTAUTH_URL": {
      "required": false
    },
    "NODE_ENV": "production"
  },
  "functions": {
    "app/api/**/*.js": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=3600"
        }
      ]
    }
  ],
  "redirects": [],
  "turbopack": {
    "root": "."
  }
}
